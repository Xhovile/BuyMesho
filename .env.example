# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Firebase Configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Admin access
# Use the real Firebase UID(s) and/or email address(es) of admin accounts.
# Keep server and client values aligned.
ADMIN_EMAILS=
VITE_ADMIN_EMAILS=
ADMIN_UIDS=
VITE_ADMIN_UIDS=

# SMTP / Email Configuration
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM="xhovilepublications@gmail.com"
SMTP_FROM_NAME="BuyMesho"
SMTP_REPLY_TO="xhovilepublications@gmail.com"

DATABASE_URL=postgresql://username:password@localhost:5432/buymesho

# PayChangu
# Set PAYCHANGU_ENABLED=true to enforce required PayChangu secrets at startup in production.
PAYCHANGU_ENABLED=false
# Optional override (defaults to https://api.paychangu.com)
PAYCHANGU_BASE_URL=
# Payments (server-side secrets only)
PAYMENTS_PROVIDER=paychangu
PAYCHANGU_BASE_URL=https://api.paychangu.com
PAYCHANGU_SECRET_KEY=
PAYCHANGU_WEBHOOK_SECRET=
