# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Firebase Configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Admin access
# Use the real Firebase UID(s) and/or email address(es) of admin accounts.
# Keep server and client values aligned.
ADMIN_EMAILS=
VITE_ADMIN_EMAILS=
ADMIN_UIDS=
VITE_ADMIN_UIDS=

# SMTP / Email Configuration
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM="xhovilepublications@gmail.com"
SMTP_FROM_NAME="BuyMesho"
SMTP_REPLY_TO="xhovilepublications@gmail.com"

DATABASE_URL=postgresql://username:password@localhost:5432/buymesho

# PayChangu Payment Gateway
# Secret key used to authenticate requests to the PayChangu API.
PAYCHANGU_SECRET_KEY=
# Webhook secret used to verify HMAC signatures on incoming webhook events.
PAYCHANGU_WEBHOOK_SECRET=
PAYCHANGU_WEBHOOK_URL=
# Optional: override the PayChangu API base URL (defaults to https://api.paychangu.com).
PAYCHANGU_BASE_URL=

# Seller payout destination encryption
# Must be a long random secret in production.
SELLER_PAYOUT_ENCRYPTION_KEY=

# PayChangu seller payout configuration
# Optional: override the PayChangu payout API base URL. Defaults to PAYCHANGU_BASE_URL or https://api.paychangu.com.
PAYCHANGU_PAYOUT_BASE_URL=
# Optional: endpoint overrides. Leave blank to use PayChangu's documented production/sandbox paths.
PAYCHANGU_MOBILE_MONEY_PAYOUT_PATH=/mobile-money/payouts/initialize
PAYCHANGU_BANK_PAYOUT_PATH=/direct-charge/payouts/initialize
PAYCHANGU_PAYOUT_STATUS_PATH=/direct-charge/payouts/{charge_id}/details
PAYCHANGU_MOBILE_MONEY_PATH=/mobile-money
PAYCHANGU_BANKS_PATH=/direct-charge/payouts/supported-banks
PAYCHANGU_PAYOUT_BALANCE_PATH=/wallet-balance
# Request timeout for PayChangu payout calls in milliseconds.
PAYCHANGU_PAYOUT_TIMEOUT_MS=20000
# Optional background worker for polling pending PayChangu payout statuses.
PAYOUT_RECONCILIATION_WORKER_ENABLED=false
PAYOUT_RECONCILIATION_WORKER_INTERVAL_MS=300000
PAYOUT_RECONCILIATION_WORKER_BATCH_LIMIT=25
